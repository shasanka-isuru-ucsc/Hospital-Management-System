          "name": "40. Filter allocations by doctor",
          "request": {
            "method": "GET",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/nurse-allocations?doctor_id={{doctorId}}&status=active",
              "host": ["{{baseUrl}}"],
              "path": ["nurse-allocations"],
              "query": [
                { "key": "doctor_id", "value": "{{doctorId}}" },
                { "key": "status",    "value": "active" }
              ]
            }
          }
        },
        {
          "name": "41. Filter allocations by date",
          "request": {
            "method": "GET",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/nurse-allocations?date=2026-03-10",
              "host": ["{{baseUrl}}"],
              "path": ["nurse-allocations"],
              "query": [{ "key": "date", "value": "2026-03-10" }]
            }
          }
        },
        {
          "name": "42. Complete an allocation",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/nurse-allocations/{{allocationId}}/complete",
              "host": ["{{baseUrl}}"],
              "path": ["nurse-allocations", "{{allocationId}}", "complete"]
            }
          }
        },
        {
          "name": "43. Complete already completed allocation (expect 422)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/nurse-allocations/{{allocationId}}/complete",
              "host": ["{{baseUrl}}"],
              "path": ["nurse-allocations", "{{allocationId}}", "complete"]
            }
          }
        },
        {
          "name": "44. Get available nurses — Sarah is free again after completion",
          "request": {
            "method": "GET",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/staff/available?date=2026-03-10&role=nurse",
              "host": ["{{baseUrl}}"],
              "path": ["staff", "available"],
              "query": [
                { "key": "date", "value": "2026-03-10" },
                { "key": "role", "value": "nurse" }
              ]
            }
          }
        },
        {
          "name": "45. Allocate nurse to non-existent doctor (expect 404)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nurse_id\": \"NURSE_ID_HERE\",\n  \"doctor_id\": \"00000000-0000-0000-0000-000000000000\",\n  \"session_date\": \"2026-03-15\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/nurse-allocations",
              "host": ["{{baseUrl}}"],
              "path": ["nurse-allocations"]
            }
          }
        },
        {
          "name": "46. Cancel an allocation",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/nurse-allocations/{{allocationId}}",
              "host": ["{{baseUrl}}"],
              "path": ["nurse-allocations", "{{allocationId}}"]
            }
          }
        },
        {
          "name": "47. Cancel already completed allocation (expect 422)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/nurse-allocations/{{allocationId}}",
              "host": ["{{baseUrl}}"],
              "path": ["nurse-allocations", "{{allocationId}}"]
            }
          }
        }
      ]
    }
  ]
}
