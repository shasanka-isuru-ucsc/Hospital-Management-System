{
  "info": {
    "name": "HMS — Staff Service",
    "description": "API collection for the HMS Staff Service (port 3003). Covers Departments, Doctors, Schedules, Staff Members, and Nurse Allocations.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",      "value": "http://localhost:3003", "type": "string" },
    { "key": "deptId",       "value": "DEPT_ID_HERE",          "type": "string" },
    { "key": "doctorId",     "value": "DOCTOR_ID_HERE",        "type": "string" },
    { "key": "scheduleId",   "value": "SCHEDULE_ID_HERE",      "type": "string" },
    { "key": "nurseId",      "value": "NURSE_ID_HERE",         "type": "string" },
    { "key": "allocationId", "value": "ALLOCATION_ID_HERE",    "type": "string" }
  ],
  "item": [
    {
      "name": "Departments",
      "item": [
        {
          "name": "1. List all departments",
          "request": {
            "method": "GET",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/departments",
              "host": ["{{baseUrl}}"],
              "path": ["departments"]
            }
          }
        },
        {
          "name": "2. Create department — Cardiology",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Cardiology\",\n  \"description\": \"Heart and cardiovascular care\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/departments",
              "host": ["{{baseUrl}}"],
              "path": ["departments"]
            }
          }
        },
        {
          "name": "3. Create department — Neurology",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Neurology\",\n  \"description\": \"Brain and nervous system disorders\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/departments",
              "host": ["{{baseUrl}}"],
              "path": ["departments"]
            }
          }
        },
        {
          "name": "4. Create department — General Physician",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"General Physician\",\n  \"description\": \"Primary care and general medicine\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/departments",
              "host": ["{{baseUrl}}"],
              "path": ["departments"]
            }
          }
        },
        {
          "name": "5. Create department — duplicate name (expect 409)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Cardiology\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/departments",
              "host": ["{{baseUrl}}"],
              "path": ["departments"]
            }
          }
        },
        {
          "name": "6. Update department — set description",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Updated: Advanced cardiovascular care and interventional cardiology\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/departments/{{deptId}}",
              "host": ["{{baseUrl}}"],
              "path": ["departments", "{{deptId}}"]
            }
          }
        },
        {
          "name": "7. Deactivate department",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"is_active\": false\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/departments/{{deptId}}",
              "host": ["{{baseUrl}}"],
              "path": ["departments", "{{deptId}}"]
            }
          }
        },
        {
          "name": "8. Delete department (expect 422 if active doctors assigned)",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/departments/{{deptId}}",
              "host": ["{{baseUrl}}"],
              "path": ["departments", "{{deptId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Doctors",
      "item": [
        {
          "name": "9. List all doctors",
          "request": {
            "method": "GET",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/doctors",
              "host": ["{{baseUrl}}"],
              "path": ["doctors"]
            }
          }
        },
        {
          "name": "10. List doctors filtered by department",
          "request": {
            "method": "GET",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/doctors?department_id={{deptId}}&status=active",
              "host": ["{{baseUrl}}"],
              "path": ["doctors"],
              "query": [
                { "key": "department_id", "value": "{{deptId}}" },
                { "key": "status",        "value": "active" }
              ]
            }
          }
        },
        {
          "name": "11. List doctors with search",
          "request": {
            "method": "GET",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/doctors?search=jenny&page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["doctors"],
              "query": [
                { "key": "search", "value": "jenny" },
                { "key": "page",   "value": "1" },
                { "key": "limit",  "value": "10" }
              ]
            }
          }
        },
        {
          "name": "12. Create doctor — Jenny Smith (multipart)",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "first_name",   "value": "Jenny",                              "type": "text" },
                { "key": "last_name",    "value": "Smith",                              "type": "text" },
                { "key": "username",     "value": "dr.jennysmith",                      "type": "text" },
                { "key": "email",        "value": "jenny.smith@hospital.com",            "type": "text" },
                { "key": "mobile",       "value": "+94771234567",                        "type": "text" },
                { "key": "password",     "value": "Password@123",                        "type": "text" },
                { "key": "date_of_birth","value": "1985-05-20",                          "type": "text" },
                { "key": "gender",       "value": "female",                              "type": "text" },
                { "key": "education",    "value": "MBBS, MS",                            "type": "text" },
