            "url": {
              "raw": "{{baseUrl}}/doctors",
              "host": ["{{baseUrl}}"],
              "path": ["doctors"]
            }
          }
        },
        {
          "name": "13. Create doctor — John Doe (multipart)",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "first_name",   "value": "John",                    "type": "text" },
                { "key": "last_name",    "value": "Doe",                     "type": "text" },
                { "key": "username",     "value": "dr.johndoe",              "type": "text" },
                { "key": "email",        "value": "john.doe@hospital.com",   "type": "text" },
                { "key": "mobile",       "value": "+94770000001",             "type": "text" },
                { "key": "password",     "value": "Password@123",             "type": "text" },
                { "key": "date_of_birth","value": "1978-08-15",               "type": "text" },
                { "key": "gender",       "value": "male",                    "type": "text" },
                { "key": "education",    "value": "MBBS, MD",                "type": "text" },
                { "key": "designation",  "value": "Consultant Physician",    "type": "text" },
                { "key": "department_id","value": "{{deptId}}",              "type": "text" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/doctors",
              "host": ["{{baseUrl}}"],
              "path": ["doctors"]
            }
          }
        },
        {
          "name": "14. Get doctor by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/doctors/{{doctorId}}",
              "host": ["{{baseUrl}}"],
              "path": ["doctors", "{{doctorId}}"]
            }
          }
        },
        {
          "name": "15. Get doctor — not found (expect 404)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/doctors/00000000-0000-0000-0000-000000000000",
              "host": ["{{baseUrl}}"],
              "path": ["doctors", "00000000-0000-0000-0000-000000000000"]
            }
          }
        },
        {
          "name": "16. Update doctor (multipart)",
          "request": {
            "method": "PUT",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "designation", "value": "Chief Cardiologist",      "type": "text" },
                { "key": "biography",   "value": "Updated biography text",  "type": "text" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/doctors/{{doctorId}}",
              "host": ["{{baseUrl}}"],
              "path": ["doctors", "{{doctorId}}"]
            }
          }
        },
        {
          "name": "17. Deactivate doctor (soft-delete + Keycloak disable)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/doctors/{{doctorId}}",
              "host": ["{{baseUrl}}"],
              "path": ["doctors", "{{doctorId}}"]
            }
          }
        }
      ]
    },
    {
