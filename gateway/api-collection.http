  "lineItems": [
    {
      "itemName": "Doctor Consultation",
      "itemType": "consultation",
      "quantity": 1,
      "unitPrice": 1500.00
    },
    {
      "itemName": "ECG",
      "itemType": "procedure",
      "quantity": 1,
      "unitPrice": 500.00
    }
